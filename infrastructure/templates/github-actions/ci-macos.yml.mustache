{{=[[ ]]=}}name: [[OS_NAME]] CI
env:
  CLOUDSMITH_API_KEY: ${{ secrets.CLOUDSMITH_API_KEY }}
  GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
  HOMEBREW_TAP_TOKEN: ${{ secrets.HOMEBREW_TAP_TOKEN }}
on:
  push:
    branches: ["main"]
    tags: ["**"]
  pull_request:
    branches: ["main"]
jobs:
  macos:
    name: [[OS_NAME]] - LLVM ${{ matrix.LLVM_VERSION }}
    runs-on: [[ OS_RUNNER ]]
    timeout-minutes: 30
    strategy:
      matrix:
        LLVM_VERSION: [[ LLVM_VERSIONS ]]
    steps:
      - name: Fix git
        run: |
          git config --global --add safe.directory $PWD
      - uses: actions/checkout@v5
      - uses: ./.github/actions/detect-package-metadata
      - uses: ./.github/actions/setup-bazel-cache
        with:
          BUILDBUDDY_API_KEY: ${{ secrets.BUILDBUDDY_API_KEY }}
      - name: Run CI task
        run: |
          brew install bazelisk zlib ncurses sqlite ninja llvm@${{ matrix.LLVM_VERSION }}
          bazel test //...
          bazel build //:mull_packages --stamp
      - name: Publish package
        if: env.CLOUDSMITH_API_KEY != null
        run: |
          bazel run publish --stamp && exit 0

          max_attempts=3
          attempt=1
          until [ "$attempt" -ge "$max_attempts" ]
          do
            echo "Attempt $attempt failed. Retrying..."
            attempt=$((attempt+1))
            bazel run publish --stamp && exit 0
          done
          echo "All $max_attempts attempts failed."
          exit 1
      - name: Trigger Homebrew tap update
        if: env.HOMEBREW_TAP_TOKEN != null && success()
        run: |
          CS_REPO=$(cat .mull-ci-cs-repo)
          MULL_VERSION=$(jq -r .mull_version bazel-bin/infrastructure/homebrew_config.json)
          PACKAGE_PATH=$(ls bazel-bin/Mull-${{ matrix.LLVM_VERSION }}-*.zip)
          PACKAGE_FILENAME=$(basename "$PACKAGE_PATH")
          PACKAGE_SHA256=$(shasum -a 256 "$PACKAGE_PATH" | cut -d' ' -f1)

          echo "Triggering Homebrew tap update:"
          echo "  Channel: $CS_REPO"
          echo "  Version: $MULL_VERSION"
          echo "  LLVM: ${{ matrix.LLVM_VERSION }}"
          echo "  Filename: $PACKAGE_FILENAME"
          echo "  SHA256: $PACKAGE_SHA256"

          curl -X POST \
            -H "Accept: application/vnd.github+json" \
            -H "Authorization: Bearer ${{ env.HOMEBREW_TAP_TOKEN }}" \
            https://api.github.com/repos/mull-project/homebrew-mull/dispatches \
            -d "{
              \"event_type\": \"update-formula\",
              \"client_payload\": {
                \"channel\": \"$CS_REPO\",
                \"mull_version\": \"$MULL_VERSION\",
                \"llvm_version\": \"${{ matrix.LLVM_VERSION }}\",
                \"package_filename\": \"$PACKAGE_FILENAME\",
                \"package_sha256\": \"$PACKAGE_SHA256\"
              }
            }"
      - name: Move package
        run: |
          mkdir -p /tmp/packages
          cp -v bazel-bin/Mull-*.zip /tmp/packages/
      - uses: ./.github/actions/attach-package
        with:
          GH_API_KEY: ${{ secrets.GITHUB_TOKEN }}
